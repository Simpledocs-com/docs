{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SimpleDocs",
  "description": "API documentation for SimpleDocs — programmatic access to legal workflows, document management, and real-time event notifications.",
  "colors": {
    "primary": "#7978FF",
    "light": "#A198D3",
    "dark": "#33326B"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://simpledocs.com"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "appearance": {
    "default": "system"
  },
  "background": {
    "color": {
      "light": "#FAFAFF",
      "dark": "#1E1D26"
    }
  },
  "styling": {
    "eyebrow": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark-dimmed"
      }
    }
  },
  "search": {
    "placeholder": "Search documentation..."
  },
  "navbar": {
    "links": [
      {
        "label": "SimpleDocs.com",
        "href": "https://simpledocs.com"
      },
      {
        "label": "Support",
        "href": "mailto:support@simpledocs.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://app.simpledocs.com"
    }
  },
  "footer": {
    "socials": {
      "website": "https://simpledocs.com",
      "linkedin": "https://linkedin.com/company/simpledocs"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          {
            "label": "SimpleDocs",
            "href": "https://simpledocs.com"
          },
          {
            "label": "Login",
            "href": "https://app.simpledocs.com"
          }
        ]
      },
      {
        "header": "Developers",
        "items": [
          {
            "label": "API Reference",
            "href": "/api-reference"
          },
          {
            "label": "Quickstart",
            "href": "/quickstart"
          },
          {
            "label": "Authentication",
            "href": "/authentication"
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "none"
    },
    "examples": {
      "languages": ["bash", "python", "javascript"]
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "authentication", "quickstart"]
          },
          {
            "group": "Guides",
            "pages": ["repository-documents-guide", "workflows-guide", "requests-guide", "webhooks-guide"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Authentication",
            "pages": ["api-reference/authentication/create-token"]
          },
          {
            "group": "Repository Documents",
            "pages": [
              "api-reference/repository-documents/list-repository-documents",
              "api-reference/repository-documents/get-repository-document",
              "api-reference/repository-documents/create-repository-document"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "api-reference/workflows/list-workflows",
              "api-reference/workflows/get-workflow",
              "api-reference/workflows/get-workflow-schema"
            ]
          },
          {
            "group": "Requests",
            "pages": [
              "api-reference/requests/list-requests",
              "api-reference/requests/get-request",
              "api-reference/requests/get-request-activity",
              "api-reference/requests/create-request"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks/list-webhooks",
              "api-reference/webhooks/create-webhook"
            ]
          }
        ]
      }
    ]
  }
}
